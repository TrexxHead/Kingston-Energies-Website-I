generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase: DATABASE_URL = pooled (port 6543, ?pgbouncer=true) for the app;
  // DIRECT_URL = direct (port 5432) for prisma db push / migrations.
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String    @unique
  emailVerified DateTime?
  password      String
  role          Role      @default(USER)
  phone         String?
  segment       CustomerSegment?
  loyaltyTier   String?
  primaryNeed   CustomerNeed?
  referralCode  String?   @unique // personal share code, e.g. KEG-24-JFEARON
  lastActiveAt  DateTime? // last time the user engaged (drives admin online status)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  leads         Lead[]
  orders        Order[]
  tickets       SupportTicket[]
  npsResponses  NpsResponse[]
  reviews       Review[]
  favorites     Favorite[]
}

// A customer's saved / favourited products. productId is the catalog id
// (e.g. "pb10") since the storefront reads lib/catalog.ts, not Product.
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  price       Float
  cost        Float?   // unit cost, for COGS / margin in the P&L
  icon        String?
  features    String[]
  sku         String?  @unique
  barcode     String?
  category    ProductCategory?
  spec        String?
  stock       Int      @default(0)
  threshold   Int      @default(5)
  badge       String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
  orderItems    OrderItem[]
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  productId String
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime @default(now())
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model EnergyData {
  id          String   @id @default(cuid())
  userId      String
  consumption Float    @default(0)
  production  Float    @default(0)
  timestamp   DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
}

model Lead {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  name      String
  phone     String?
  message   String   @db.Text
  status    LeadStatus @default(NEW)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Order {
  id           String      @id @default(cuid())
  orderNo       String      @unique
  userId        String?
  customerName  String
  status        OrderStatus @default(PENDING)
  source        OrderChannel @default(WEBSITE)
  contact       String?     // WhatsApp number / Instagram handle for off-site orders
  paymentMethod String?
  paid          Boolean     @default(false) // payment received/confirmed
  invoicedAt    DateTime?   // when an invoice was issued/sent (prevents dupes)
  total         Float       @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@index([userId])
}

// Where an order originated — lets the dashboard tag WhatsApp/Instagram orders
// distinctly from website checkouts.
enum OrderChannel {
  WEBSITE
  WHATSAPP
  INSTAGRAM
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  name      String
  qty       Int     @default(1)
  price     Float

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Supplier {
  id           String   @id @default(cuid())
  name         String
  contactEmail String?
  contactPhone String?
  website      String?
  address      String?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  files          ProcurementFile[]
}

model PurchaseOrder {
  id         String   @id @default(cuid())
  supplierId String
  reference  String
  status     POStatus @default(OPEN)
  amount     Float?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  supplier Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  files    ProcurementFile[]

  @@index([supplierId])
}

// A procurement attachment — an uploaded file OR an external link — hung off a
// supplier and/or a purchase order. Covers invoices, quotes, price lists,
// contracts and reference links ("anything relevant to procurement").
model ProcurementFile {
  id              String            @id @default(cuid())
  label           String
  kind            ProcurementKind   @default(OTHER)
  url             String?           // external link — null when it's an uploaded file
  storagePath     String?           // Supabase Storage key — null when it's a link
  fileName        String?           // original filename, for display/download
  supplierId      String?
  purchaseOrderId String?
  createdAt       DateTime          @default(now())

  supplier      Supplier?      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([purchaseOrderId])
}

enum ProcurementKind {
  INVOICE
  QUOTE
  PRICE_LIST
  CONTRACT
  LINK
  OTHER
}

model SupportTicket {
  id           String       @id @default(cuid())
  userId       String?
  customerName String
  subject      String
  status       TicketStatus @default(OPEN)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  productId String   // catalog product id (e.g. "pb10") — the shop reads lib/catalog.ts, not Product
  userId    String?
  author    String
  location  String?
  rating    Int      @default(5)
  body      String   @db.Text
  verified  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // One review per customer per product (seeded reviews have userId = null and
  // are unaffected — the constraint only binds rows that have a userId).
  @@unique([userId, productId])
  @@index([productId])
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum CustomerSegment {
  VIP
  REPEAT
  NEW
}

// IDIC "Identify" — the primary use-case a customer's portable-power purchase
// serves. Kept in sync with CUSTOMER_NEEDS in lib/crm.ts.
enum CustomerNeed {
  EVERYDAY
  BACKUP
  OFFGRID
  BUSINESS
}

// IDIC "Interact" — a Net Promoter Score response collected after an order or
// a Jordyn support interaction. Score is 0–10; see lib/crm.ts for bucketing.
model NpsResponse {
  id        String    @id @default(cuid())
  userId    String?
  score     Int
  comment   String?   @db.Text
  source    NpsSource @default(ORDER)
  orderNo   String?
  createdAt DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([source])
}

enum NpsSource {
  ORDER
  SUPPORT
}

// Admin policy / documentation links — e.g. Google Drive share URLs for SOPs,
// warranty policy, staff guides. Stored as links so no Drive API is required.
model PolicyDoc {
  id          String   @id @default(cuid())
  title       String
  url         String?  // external link (Drive etc.) — null when it's an uploaded file
  storagePath String?  // Supabase Storage key — null when it's an external link
  fileName    String?  // original filename, for display/download
  category    String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

enum ProductCategory {
  POWERBANKS
  CHARGERS
  STATIONS
  ACCESSORIES
}

// Generic key/value store for admin-editable site settings (e.g. the payment
// methods config JSON under key "payments"). Avoids a migration per setting.
model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// A logged business expense — the manual side of the Finance section (revenue
// comes automatically from orders).
model Expense {
  id          String   @id @default(cuid())
  category    String
  description String?
  amount      Float
  spentAt     DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([spentAt])
}

// A recurring monthly budget target per expense category.
model Budget {
  id            String   @id @default(cuid())
  category      String   @unique
  monthlyAmount Float
  updatedAt     DateTime @updatedAt
}

// An admin-managed promo/discount code applied at checkout.
model DiscountCode {
  id          String       @id @default(cuid())
  code        String       @unique
  type        DiscountType @default(PERCENT)
  value       Float        // percent (0–100) for PERCENT, J$ off for FIXED
  minSpend    Float?       // minimum cart subtotal to qualify
  active      Boolean      @default(true)
  expiresAt   DateTime?
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum DiscountType {
  PERCENT
  FIXED
}

// A marketing campaign the admin can categorise, schedule and action (email
// blasts send for real via Resend; other channels are tracked/handled via your
// external tooling e.g. n8n/WhatsApp).
model Campaign {
  id             String          @id @default(cuid())
  name           String
  channel        CampaignChannel @default(EMAIL)
  category       String?
  subject        String?
  body           String?         @db.Text
  status         CampaignStatus  @default(DRAFT)
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([createdAt])
}

enum CampaignChannel {
  EMAIL
  SMS
  PUSH
  SOCIAL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
}

enum OrderStatus {
  PENDING
  PACKED
  OUT
  DONE
  CANCELLED
}

enum POStatus {
  OPEN
  RECEIVED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}
