# Database (Supabase: Project Settings → Database → Connection string)
# DATABASE_URL = "Transaction" pooler (port 6543) + ?pgbouncer=true — used by the app.
# DIRECT_URL   = "Session"/direct connection (port 5432) — used by prisma db push/migrate.
DATABASE_URL="postgresql://user:password@localhost:5432/kingston_energies"
DIRECT_URL="postgresql://user:password@localhost:5432/kingston_energies"

# Admin seed credentials — SET THESE before seeding a public database.
ADMIN_EMAIL="admin@kingstonenergies.com"
ADMIN_PASSWORD=""

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (create credentials at https://console.cloud.google.com/apis/credentials
# -> OAuth client ID -> Web application -> Authorized redirect URI:
# http://localhost:3000/api/auth/callback/google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Jordyn AI assistant — get a key at https://console.anthropic.com/settings/keys
# Without it (or without account credit), Jordyn falls back to built-in navigation help.
ANTHROPIC_API_KEY=""

# Public site URL — used for SEO metadata (Open Graph, canonical). Set to the real domain in prod.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Transactional email (order confirmations + signup verification) — Resend by default
# (https://resend.com). Without both, emails are skipped gracefully and logged to the
# server console instead — including the verification link, so signup stays testable locally.
EMAIL_API_KEY=""
EMAIL_FROM="Kingston Energies <orders@kingstonenergies.com>"

# Payments — checkout records the chosen method now; live capture needs these.
# PayPal: create credentials at https://developer.paypal.com/dashboard/ (Apps & Credentials)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# Google Pay merchant ID: https://pay.google.com/business/console
NEXT_PUBLIC_GOOGLE_PAY_MERCHANT_ID=""

# Live Google Sheets sync (admin dashboard "Sync now" + auto every 15 min in prod).
# Service account setup steps are in DEPLOY.md. Empty = the sync card shows "Not configured".
GOOGLE_SHEETS_CLIENT_EMAIL=""
GOOGLE_SHEETS_PRIVATE_KEY=""
GOOGLE_SHEETS_SPREADSHEET_ID=""
# Secret Vercel Cron sends as `Authorization: Bearer $CRON_SECRET` to trigger the sync on schedule.
CRON_SECRET=""

# Optional: a Google Drive folder URL surfaced as an "Open Drive folder" button
# in the admin Playbook → Policies & documentation section.
NEXT_PUBLIC_DRIVE_FOLDER_URL=""

# Environment
NODE_ENV="development"
